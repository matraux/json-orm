{
	"name": "matraux/json-orm",
	"description": "A PHP 8.3+ library for converting JSON data to typed entities and back, with support for lazy-loading collections.",
	"keywords": ["JSON ORM", "json-orm", "MATRAUX"],
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Daniel Žůrek",
			"email": "info@danielzurek.cz",
			"homepage": "https://www.matraux.com"
		}
	],
	"require": {
		"php": "^8.3"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"codeception/codeception": "^5.3",
		"codeception/module-asserts": "^3.3",
		"friendsofphp/php-cs-fixer": "^3.94"
	},
	"autoload": {
		"psr-4": {
			"Matraux\\JsonOrm\\": "src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Matraux\\JsonOrm\\Test\\": "tests"
		}
	},
	"support": {
		"issues": "https://github.com/matraux/json-orm/issues",
		"source": "https://github.com/matraux/json-orm"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"cs:check": "vendor/bin/php-cs-fixer check",
		"cs:fix": "vendor/bin/php-cs-fixer fix",
		"phpstan": "vendor/bin/phpstan analyse --ansi",
		"tests:build": "vendor/bin/codecept build",
		"tests:run": "vendor/bin/codecept run"
	},
	"scripts-descriptions": {
		"cs:check": "Check code style",
		"cs:fix": "Fix code style",
		"phpstan": "Static code analysis",
		"tests:build": "Build Codeception actors",
		"tests:run": "Run Codeception tests"
	}
}
